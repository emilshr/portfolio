# Database connection string
DATABASE_URL=mongodb://127.0.0.1/portfolio

# Used to encrypt JWT tokens
PAYLOAD_SECRET=YOUR_SECRET_HERE

# Used to configure CORS, format links and more. No trailing slash
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Secret used to authenticate cron jobs
CRON_SECRET=YOUR_CRON_SECRET_HERE

# Used to validate preview requests
PREVIEW_SECRET=YOUR_SECRET_HERE

# Seed admin user (optional, for pnpm seed)
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=changeme

# Cloudflare R2 (optional — omit to use local public/media storage)
R2_BUCKET=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
R2_PUBLIC_URL=https://media.example.com

# Railway mapping notes:
# - DATABASE_URL: reference from your Railway MongoDB service connection URL.
# - For Railway Object Storage, map generated AWS-style vars to these names:
#   - R2_BUCKET <- AWS_S3_BUCKET_NAME
#   - R2_ACCESS_KEY_ID <- AWS_ACCESS_KEY_ID
#   - R2_SECRET_ACCESS_KEY <- AWS_SECRET_ACCESS_KEY
#   - R2_ENDPOINT <- AWS_ENDPOINT_URL
# - R2_PUBLIC_URL is optional: use your public bucket/custom CDN URL if configured.

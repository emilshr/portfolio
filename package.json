{
  "name": "astro-chiri",
  "type": "module",
  "version": "1.0.0",
  "license": "MIT",
  "scripts": {
    "dev": "astro dev",
    "prebuild": "pnpm exec tsx scripts/toggle-proxy.ts",
    "build": "pnpm run typecheck && pnpm run prebuild && astro build",
    "typecheck": "pnpm run typecheck:ts && astro check",
    "typecheck:ts": "tsc --noEmit",
    "preview": "astro preview",
    "astro": "astro",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "new": "tsx scripts/new-post.ts",
    "update-theme": "tsx scripts/update-theme.ts"
  },
  "dependencies": {
    "@astrojs/mdx": "^5.0.3",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.2",
    "@astrojs/vercel": "^10.0.4",
    "astro": "^6.1.6",
    "astro-og-canvas": "^0.11.0",
    "canvaskit-wasm": "^0.41.1",
    "feed": "^5.2.0",
    "katex": "^0.16.45",
    "markdown-it": "^14.1.1",
    "mdast-util-to-string": "^4.0.0",
    "node-html-parser": "^7.1.0",
    "reading-time": "^1.5.0",
    "rehype-katex": "^7.0.1",
    "remark-directive": "^4.0.0",
    "remark-math": "^6.0.0",
    "sanitize-html": "^2.17.2",
    "sharp": "^0.34.5",
    "unist-util-visit": "^5.1.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "@biomejs/biome": "^2.2.6",
    "@types/markdown-it": "^14.1.2",
    "@types/sanitize-html": "^2.16.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}

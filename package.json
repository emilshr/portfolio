{
  "name": "portfolio-monorepo",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "dev:portfolio": "turbo dev --filter=portfolio",
    "dev:journeys": "turbo dev --filter=journeys",
    "lint": "turbo lint",
    "lint:fix": "turbo lint:fix",
    "format": "turbo format",
    "format:check": "turbo format:check",
    "check-types": "turbo check-types",
    "generate:types": "turbo generate:types --filter=portfolio",
    "generate:importmap": "turbo generate:importmap --filter=portfolio",
    "payload": "pnpm --filter portfolio payload",
    "seed": "pnpm --filter portfolio seed",
    "test": "turbo test --filter=portfolio",
    "test:int": "turbo test:int --filter=portfolio",
    "test:e2e": "turbo test:e2e --filter=portfolio"
  },
  "devDependencies": {
    "turbo": "catalog:"
  },
  "engines": {
    "node": "24.16.0",
    "pnpm": "11.5.0"
  },
  "packageManager": "pnpm@11.5.0"
}

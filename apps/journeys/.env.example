# Payload REST API (portfolio CMS deployment) — required for content + media URLs
PAYLOAD_API_URL=http://localhost:3000/api
# Set the same value in production if PAYLOAD_API_URL is missing on Vercel (build + client)
NEXT_PUBLIC_PAYLOAD_API_URL=http://localhost:3000/api

# Public site URL (canonical, OG links)
NEXT_PUBLIC_SITE_URL=https://burntclutchproject.com

# Portfolio origin when CMS is on a different domain (production on Vercel)
NEXT_PUBLIC_MEDIA_BASE_URL=https://emilshr.com

# Optional: media CDN hostname if different from API host (e.g. R2 public URL hostname)
# NEXT_PUBLIC_MEDIA_HOST=media.example.com

# Shared with portfolio REVALIDATE_SECRET — POST /api/revalidate
REVALIDATE_SECRET=YOUR_SECRET_HERE

# Umami analytics (optional)
NEXT_PUBLIC_UMAMI_SRC=https://cloud.umami.is/script.js
NEXT_PUBLIC_UMAMI_WEBSITE_ID_JOURNEYS=

# Vercel deploy notes (journeys project — root apps/journeys):
# - PAYLOAD_API_URL=https://emilshr.com/api (portfolio production domain)
# - NEXT_PUBLIC_MEDIA_BASE_URL=https://emilshr.com (for OG/metadata absolutes)
# - Point burntclutchproject.com DNS to the journeys Vercel project
# - Add https://burntclutchproject.com to portfolio JOURNEYS_SITE_URL for CORS

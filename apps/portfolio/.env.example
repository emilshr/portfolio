# Database connection string (MongoDB Atlas M0 in production)
DATABASE_URL=mongodb://127.0.0.1/portfolio

# Used to encrypt JWT tokens
PAYLOAD_SECRET=YOUR_SECRET_HERE

# Used to configure CORS, format links and more. No trailing slash
NEXT_PUBLIC_SERVER_URL=http://localhost:3000
# Optional extra production URLs (comma-separated, e.g. www + apex)
PRODUCTION_URLS=https://www.example.com,https://example.com

# Secret used to authenticate cron jobs
CRON_SECRET=YOUR_CRON_SECRET_HERE

# Used to validate preview requests
PREVIEW_SECRET=YOUR_SECRET_HERE

# Seed admin user (optional, for pnpm seed)
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=changeme

# Cloudflare R2 — required on Vercel (no persistent disk for local media)
R2_BUCKET=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
R2_PUBLIC_URL=https://media.example.com

# Resend email adapter (required for auth emails like password reset)
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@example.com
RESEND_FROM_NAME=Portfolio

# Umami Cloud analytics (optional)
NEXT_PUBLIC_UMAMI_SRC=https://cloud.umami.is/script.js
NEXT_PUBLIC_UMAMI_WEBSITE_ID_PORTFOLIO=
NEXT_PUBLIC_UMAMI_WEBSITE_ID_JOURNEYS=

# Journeys travel blog (burntclutchproject.com)
JOURNEYS_SITE_URL=https://burntclutchproject.com
# POST endpoint on journeys app (must match apps/journeys REVALIDATE_SECRET)
JOURNEYS_REVALIDATE_URL=https://burntclutchproject.com/api/revalidate
# Shared secret with apps/journeys REVALIDATE_SECRET
REVALIDATE_SECRET=

# Vercel deploy notes (portfolio project — root apps/portfolio):
# - DATABASE_URL: MongoDB Atlas SRV connection string (migrate from Railway with mongodump/restore)
# - Set NEXT_PUBLIC_SERVER_URL to your production domain (e.g. https://emilshr.com)
# - Enable "Include source files outside of Root Directory" for packages/payload-types
# - VERCEL_URL / VERCEL_PROJECT_PRODUCTION_URL are set automatically by Vercel
# - Run pnpm seed locally against Atlas; deployed /next/seed exceeds Hobby 10s timeout

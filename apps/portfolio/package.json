{
  "name": "portfolio",
  "version": "1.0.0",
  "private": true,
  "description": "Emil portfolio — Payload CMS + Next.js",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "cross-env NODE_OPTIONS=--no-deprecation next build",
    "postbuild": "next-sitemap --config next-sitemap.config.cjs",
    "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev --port 3000",
    "dev:prod": "cross-env NODE_OPTIONS=--no-deprecation rm -rf .next && pnpm build && pnpm start",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "lint": "cross-env NODE_OPTIONS=--no-deprecation oxlint .",
    "lint:fix": "cross-env NODE_OPTIONS=--no-deprecation oxlint --fix .",
    "format": "cross-env NODE_OPTIONS=--no-deprecation oxfmt .",
    "format:check": "cross-env NODE_OPTIONS=--no-deprecation oxfmt --check .",
    "check-types": "tsc --noEmit",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "seed": "cross-env NODE_OPTIONS=--no-deprecation tsx scripts/seed.ts",
    "migrate:pub-date": "cross-env NODE_OPTIONS=--no-deprecation tsx scripts/migrate-pubdate-to-published-at.ts",
    "migrate:travels-to-articles": "cross-env NODE_OPTIONS=--no-deprecation tsx scripts/migrate-travels-to-articles.ts",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start",
    "test": "pnpm run test:int && pnpm run test:e2e",
    "test:e2e": "cross-env NODE_OPTIONS=\"--no-deprecation --import=tsx/esm\" playwright test --config=playwright.config.ts",
    "test:int": "cross-env NODE_OPTIONS=--no-deprecation vitest run --config ./vitest.config.mts"
  },
  "dependencies": {
    "@bprogress/next": "catalog:",
    "@payloadcms/admin-bar": "catalog:",
    "@payloadcms/db-mongodb": "catalog:",
    "@payloadcms/email-resend": "catalog:",
    "@payloadcms/live-preview-react": "catalog:",
    "@payloadcms/next": "catalog:",
    "@payloadcms/plugin-form-builder": "catalog:",
    "@payloadcms/plugin-nested-docs": "catalog:",
    "@payloadcms/plugin-redirects": "catalog:",
    "@payloadcms/plugin-search": "catalog:",
    "@payloadcms/plugin-seo": "catalog:",
    "@payloadcms/richtext-lexical": "catalog:",
    "@payloadcms/storage-r2": "catalog:",
    "@payloadcms/storage-s3": "catalog:",
    "@payloadcms/ui": "catalog:",
    "@radix-ui/react-checkbox": "catalog:",
    "@radix-ui/react-dialog": "catalog:",
    "@radix-ui/react-label": "catalog:",
    "@radix-ui/react-select": "catalog:",
    "@radix-ui/react-slot": "catalog:",
    "@repo/payload-types": "workspace:*",
    "@repo/ui": "workspace:*",
    "@vercel/analytics": "catalog:",
    "class-variance-authority": "catalog:",
    "clsx": "catalog:",
    "cross-env": "catalog:",
    "dotenv": "catalog:",
    "feed": "catalog:",
    "geist": "catalog:",
    "graphql": "catalog:",
    "gray-matter": "catalog:",
    "lucide-react": "catalog:",
    "markdown-it": "catalog:",
    "motion": "catalog:",
    "next": "catalog:",
    "next-sitemap": "catalog:",
    "payload": "catalog:",
    "prism-react-renderer": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-hook-form": "catalog:",
    "reading-time": "catalog:",
    "sanitize-html": "catalog:",
    "sharp": "catalog:",
    "tailwind-merge": "catalog:"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "catalog:",
    "@tailwindcss/postcss": "catalog:",
    "@tailwindcss/typography": "catalog:",
    "@testing-library/react": "catalog:",
    "@types/escape-html": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@types/sanitize-html": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "autoprefixer": "catalog:",
    "jsdom": "catalog:",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "postcss": "catalog:",
    "tailwindcss": "catalog:",
    "tsx": "catalog:",
    "tw-animate-css": "catalog:",
    "typescript": "catalog:",
    "vite-tsconfig-paths": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": "^18.20.2 || >=20.9.0",
    "pnpm": "^9 || ^10 || ^11"
  }
}

<dialog id="experience-dialog" class="experience-dialog" aria-labelledby="exp-dialog-title">
  <div class="dialog-panel">
    <button type="button" class="close-button" aria-label="Close">
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <path
          d="M4 4L12 12M12 4L4 12"
          stroke="currentColor"
          stroke-width="1.25"
          stroke-linecap="round"></path>
      </svg>
    </button>
    <header class="dialog-header">
      <h2 id="exp-dialog-title" class="dialog-title"></h2>
      <p class="dialog-subtitle">
        <a id="exp-dialog-company" class="dialog-company" href="#" target="_blank" rel="noopener noreferrer"></a><span
          id="exp-dialog-dates"
          class="dialog-dates"></span>
      </p>
    </header>
    <div id="exp-dialog-body" class="dialog-body prose"></div>
  </div>
</dialog>

<script>
  function initExperienceDialog() {
    const dialog = document.getElementById('experience-dialog') as HTMLDialogElement | null
    if (!dialog || dialog.dataset.expDialogInitialized) return
    dialog.dataset.expDialogInitialized = 'true'

    const titleEl = document.getElementById('exp-dialog-title')
    const companyEl = document.getElementById('exp-dialog-company') as HTMLAnchorElement | null
    const datesEl = document.getElementById('exp-dialog-dates')
    const bodyEl = document.getElementById('exp-dialog-body')
    const closeButton = dialog.querySelector('.close-button') as HTMLButtonElement | null
    const panel = dialog.querySelector('.dialog-panel') as HTMLDivElement | null

    if (!titleEl || !companyEl || !datesEl || !bodyEl || !closeButton || !panel) return

    const dialogEl = dialog
    const title = titleEl
    const company = companyEl
    const dates = datesEl
    const body = bodyEl
    const closeBtn = closeButton
    const panelEl = panel

    let trigger: HTMLElement | null = null
    let closing = false

    function openExperience(row: HTMLElement) {
      const id = row.dataset.expId
      const panelSource = id
        ? document.querySelector<HTMLElement>(`.exp-panel[data-exp-id="${id}"]`)
        : null
      if (!panelSource) return

      trigger = row
      title.textContent = row.dataset.expTitle ?? ''
      company.textContent = row.dataset.expCompany ?? ''
      company.href = row.dataset.expUrl ?? '#'
      dates.textContent = ` · ${row.dataset.expFrom ?? ''} – ${row.dataset.expTo ?? ''}`
      body.innerHTML = panelSource.innerHTML

      document.body.classList.add('experience-dialog-open')
      document.body.style.overflow = 'hidden'
      dialogEl.showModal()
      requestAnimationFrame(() => {
        dialogEl.classList.add('is-open')
        panelEl.classList.add('is-open')
      })
      closeBtn.focus()
    }

    function closeExperience() {
      if (closing || !dialogEl.open) return
      closing = true
      dialogEl.classList.remove('is-open')
      panelEl.classList.remove('is-open')

      const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches
      const duration = reducedMotion ? 0 : 400

      window.setTimeout(() => {
        dialogEl.close()
        document.body.classList.remove('experience-dialog-open')
        document.body.style.overflow = ''
        body.innerHTML = ''
        if (trigger) {
          trigger.focus()
          trigger = null
        }
        closing = false
      }, duration)
    }

    document.querySelectorAll<HTMLElement>('.experience-row').forEach((row) => {
      if (row.dataset.expRowBound) return
      row.dataset.expRowBound = 'true'

      row.addEventListener('click', () => openExperience(row))
      row.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' || e.key === ' ') {
          e.preventDefault()
          openExperience(row)
        }
      })
    })

    closeBtn.addEventListener('click', closeExperience)

    dialogEl.addEventListener('click', (e) => {
      if (e.target === dialogEl) closeExperience()
    })

    dialogEl.addEventListener('cancel', (e) => {
      e.preventDefault()
      closeExperience()
    })

    dialogEl.addEventListener('close', () => {
      if (!closing) {
        document.body.classList.remove('experience-dialog-open')
        document.body.style.overflow = ''
      }
    })
  }

  document.addEventListener('astro:page-load', initExperienceDialog)
</script>

<style>
  .experience-dialog {
    border: none;
    outline: none;
    padding: 0;
    margin: auto;
    max-width: min(35rem, calc(100vw - 2rem));
    width: calc(100vw - 2rem);
    max-height: 90vh;
    background: transparent;
    overflow: visible;
    box-shadow: none;
  }

  .experience-dialog:focus,
  .experience-dialog:focus-visible {
    outline: none;
  }

  .experience-dialog::backdrop {
    background: color-mix(in srgb, var(--bg) 82%, transparent);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    opacity: 0;
    transition:
      opacity 0.4s cubic-bezier(0.4, 0, 0.2, 1),
      backdrop-filter 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .experience-dialog.is-open::backdrop {
    opacity: 1;
  }

  .dialog-panel {
    position: relative;
    display: flex;
    flex-direction: column;
    max-height: 90vh;
    padding: 1.5rem 1.25rem 1.25rem;
    background: var(--bg);
    border: 0.5px solid var(--border);
    border-radius: 0;
    box-shadow: none;
    outline: none;
    opacity: 0;
    filter: blur(8px);
    transform: translateZ(0);
    transition:
      opacity 0.4s cubic-bezier(0.4, 0, 0.2, 1),
      filter 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .dialog-panel.is-open {
    opacity: 1;
    filter: blur(0);
    transition:
      opacity 0.4s ease 0.2s,
      filter 0.4s ease 0.2s;
  }

  @media (prefers-reduced-motion: reduce) {
    .experience-dialog::backdrop {
      backdrop-filter: none;
      -webkit-backdrop-filter: none;
      transition: opacity 0.15s ease;
    }

    .experience-dialog::backdrop,
    .dialog-panel {
      transition: none;
    }

    .dialog-panel.is-open {
      filter: none;
    }
  }

  .close-button {
    position: absolute;
    top: 0;
    right: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 1.75rem;
    height: 1.75rem;
    padding: 0;
    border: none;
    background: transparent;
    color: var(--text-tertiary);
    cursor: pointer;
    border-radius: 0;
    transition: color 0.2s ease-out;
    z-index: 1;
  }

  .close-button:hover {
    color: var(--text-secondary);
  }

  .dialog-header {
    flex-shrink: 0;
    padding-right: 2rem;
    margin-bottom: 1.75rem;
  }

  .dialog-title {
    margin: 0 0 0.375rem;
    font-size: var(--font-size-m);
    font-weight: var(--font-weight-bold);
    color: var(--text-primary);
    line-height: 1.3;
  }

  .dialog-subtitle {
    margin: 0;
    font-size: var(--font-size-s);
    line-height: 1.5;
  }

  .dialog-company {
    color: var(--text-secondary);
    text-decoration: none;
    transition: color 0.2s ease-out;
  }

  .dialog-company:hover {
    color: var(--text-primary);
  }

  .dialog-dates {
    color: var(--text-secondary);
    opacity: 0.75;
    font-weight: var(--font-weight-light);
    font-variant-numeric: tabular-nums;
    font-feature-settings:
      'tnum' 1,
      'zero' 0,
      'cv01' 1,
      'cv02' 1,
      'calt' 1,
      'ss03' 1,
      'ordn' 1;
  }

  .dialog-body {
    flex: 1;
    min-height: 0;
    overflow-y: auto;
    margin: 0;
    padding: 0.25rem 0 0;
    color: var(--text-primary);
  }

  .dialog-body :global(p) {
    margin: 0 0 1em;
    color: var(--text-secondary);
    line-height: 1.65;
  }

  .dialog-body :global(p:last-child) {
    margin-bottom: 0;
  }

  body.experience-dialog-open {
    overflow: hidden;
  }
</style>

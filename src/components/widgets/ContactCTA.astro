---
const links = [
  {
    label: 'Schedule a call',
    url: 'https://cal.eu/emil-sharier',
    icon: 'calendar'
  },
  {
    label: 'LinkedIn',
    url: 'https://www.linkedin.com/in/emilsharier',
    icon: 'linkedin'
  },
  {
    label: 'GitHub',
    url: 'https://github.com/emilshr',
    icon: 'github'
  }
]
---

<section class="contact-cta">
  <h2 class="section-heading">Connect</h2>
  <ul>
    {
      links.map((link) => (
        <li>
          <a href={link.url} target="_blank" rel="noopener noreferrer">
            {link.icon === "calendar" && (
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                <rect x="2" y="3" width="12" height="11" rx="1.5" stroke="currentColor" stroke-width="1.25" />
                <path d="M2 6.5h12" stroke="currentColor" stroke-width="1.25" />
                <path d="M5.5 1.5v3M10.5 1.5v3" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" />
              </svg>
            )}
            {link.icon === "linkedin" && (
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M4.5 6.5v5M4.5 4v.01" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round" />
                <path d="M8 11.5v-3a2 2 0 1 1 4 0v3" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round" />
                <rect x="1.5" y="1.5" width="13" height="13" rx="2" stroke="currentColor" stroke-width="1.25" />
              </svg>
            )}
            {link.icon === "github" && (
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M6 13.5c-2.7.9-2.7-1.3-4-1.5m8 3v-2.2c.1-.5-.1-1-.4-1.4 2.1-.2 4.4-1 4.4-4.8 0-1-.4-2-1.1-2.7.2-.7.2-1.4-.1-2-.2-.7-1.3-.8-2.8.4a9.4 9.4 0 0 0-5 0C3.5 1.9 2.4 2 2.2 2.6c-.3.7-.3 1.4-.1 2-.7.8-1.1 1.7-1.1 2.7 0 3.8 2.3 4.6 4.4 4.8-.3.3-.4.8-.4 1.4V15" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            )}
            <span>{link.label}</span>
          </a>
        </li>
      ))
    }
  </ul>
</section>

<style>
  .section-heading {
    font-weight: var(--font-weight-bold);
    font-size: var(--font-size-m);
    margin: 0 0 0.5rem 0;
    color: var(--text-primary);
  }

  ul {
    padding: 0;
    margin: 0;
    list-style-type: none;
    display: flex;
    gap: 1rem;
  }

  li {
    transition: opacity 0.15s ease-out;
  }

  @media (hover: hover) and (pointer: fine) {
    ul:hover li {
      opacity: 0.4;
    }

    ul:hover li:hover {
      opacity: 1;
    }
  }

  a {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    padding: 0.5rem 0;
    color: var(--text-secondary);
    text-decoration: none;
    font-size: var(--font-size-s);
    transition: color 0.2s ease-out;
  }

  a:hover {
    color: var(--text-primary);
  }

  svg {
    flex-shrink: 0;
  }
</style>

<div class="open-to-work-banner">
  <span>Open to work / contracting</span>
  <!-- <span class="separator">&middot;</span> -->
  <a href="https://cal.eu/emil-sharier" target="_blank" rel="noopener noreferrer">Schedule a call</a>
</div>

<style>
  .open-to-work-banner {
    font-size: var(--font-size-s);
    color: var(--text-secondary);
    background-color: var(--code-bg);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 0.5rem 0.875rem;
    margin-top: 1.5rem;
    display: flex;
    justify-content: space-between;
  }

  .separator {
    margin: 0 0.3em;
  }

  .open-to-work-banner a {
    color: var(--text-secondary);
    text-decoration: underline;
    text-decoration-color: var(--text-tertiary);
    transition: color 0.2s ease-out, text-decoration-color 0.2s ease-out;
  }

  .open-to-work-banner a:hover {
    color: var(--text-primary);
    text-decoration-color: var(--text-primary);
  }
</style>

---
import ExperienceDialog from '@/components/ui/ExperienceDialog.astro'
import { themeConfig } from '@/config'
import { getCollection, render } from 'astro:content'

const entries = await getCollection('experiences')
const sorted = entries.sort((a, b) => a.data.order - b.data.order)
const rendered = await Promise.all(
  sorted.map(async (entry) => {
    const { Content } = await render(entry)
    return { entry, Content }
  })
)
---

<section class="work-experience">
  <h2 class="section-heading">Work</h2>
  <ul>
    {
      rendered.map(({ entry }) => (
        <li>
          <div
            role="button"
            tabindex="0"
            class="experience-row"
            data-exp-id={entry.id}
            data-exp-title={entry.data.title}
            data-exp-company={entry.data.company}
            data-exp-url={entry.data.url}
            data-exp-from={entry.data.from}
            data-exp-to={entry.data.to}
          >
            <div class="experience-item">
              <div class="role-group">
                <p class="role">{entry.data.title}</p>
                <span class="company">{entry.data.company}</span>
              </div>
              <div class={themeConfig.general.postListDottedDivider ? 'dotted-divider' : 'divider'} />
              <p class="date font-features">
                {entry.data.from} &ndash; {entry.data.to}
              </p>
            </div>
          </div>
        </li>
      ))
    }
  </ul>
  <div class="exp-panels" hidden aria-hidden="true">
    {
      rendered.map(({ entry, Content }) => (
        <div class="exp-panel" data-exp-id={entry.id}>
          <Content />
        </div>
      ))
    }
  </div>
  <ExperienceDialog />
  <div class="placeholder"></div>
</section>

<style>
  .section-heading {
    font-weight: var(--font-weight-bold);
    font-size: var(--font-size-m);
    margin: 0 0 0.5rem 0;
    color: var(--text-primary);
  }

  ul {
    padding: 0;
    margin: 0;
    list-style-type: none;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .experience-row {
    display: block;
    width: 100%;
    padding: 0;
    margin: 0;
    border: none;
    background: none;
    color: var(--text-primary);
    text-align: left;
    cursor: pointer;
    transition: opacity 0.15s ease-out;
  }

  .experience-row:focus,
  .experience-row:focus-visible {
    outline: none;
  }

  @media (hover: hover) and (pointer: fine) {
    ul:hover .experience-row {
      opacity: 0.4;
    }

    ul:hover .experience-row:hover {
      opacity: 1;
    }

    ul:hover .experience-row:hover .divider {
      background-color: var(--text-tertiary);
      opacity: 0.75;
    }

    ul:hover .experience-row:hover .dotted-divider {
      color: var(--text-secondary);
    }

    ul:hover .experience-row:hover .date {
      color: var(--text-secondary);
      opacity: 1;
    }

    ul:hover .experience-row:hover .company {
      color: var(--text-primary);
    }
  }

  .experience-item {
    padding: 0.5rem 0;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 0.75rem;
  }

  .role-group {
    flex-shrink: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
  }

  .role {
    margin: 0;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .company {
    font-size: var(--font-size-s);
    color: var(--text-secondary);
    transition: color 0.2s ease-out;
  }

  .divider {
    flex: 1 1 auto;
    min-width: 3rem;
    margin: 0 0.25rem;
    height: 0.5px;
    background-color: var(--border);
  }

  .dotted-divider {
    flex: 1 1 3rem;
    min-width: 3rem;
    max-width: 100%;
    text-align: end;
    letter-spacing: 5px;
    height: 1.675rem;
    overflow: hidden;
    color: var(--text-tertiary);
    opacity: 0.75;
  }

  .dotted-divider::after {
    content: '·····························································································································································';
    pointer-events: none;
  }

  .exp-panels {
    display: none;
  }

  .placeholder {
    height: 3rem;
  }
</style>
